# Public application URL, e.g. https://chadwallet-web.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Privy dashboard credentials. Without these, the app uses a clearly marked local demo auth.
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Birdeye server-side Data API key. Without it, API routes return deterministic demo data.
BIRDEYE_API_KEY=

# Alchemy Solana RPC endpoints. Public mainnet is used only as a limited fallback.
ALCHEMY_SOLANA_RPC_URL=
ALCHEMY_SOLANA_WS_URL=

# Jupiter API key. Quote endpoints can fall back to keyless access with stricter limits.
JUPITER_API_KEY=

# Keep false until a controlled mainnet QA swap succeeds.
NEXT_PUBLIC_ENABLE_LIVE_TRADING=false

# Optional persistence. Supabase is not used for authentication.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional Advanced Charts self-hosted library path.
NEXT_PUBLIC_TRADINGVIEW_LIBRARY_PATH=

# Optional monitoring.
SENTRY_DSN=
